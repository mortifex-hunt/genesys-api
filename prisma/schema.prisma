generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  username     String      @unique
  passwordHash String
  role         String      @default("user")
  characters   Character[]
}

model Character {
  id               String   @id
  characterName    String
  speciesArchetype String
  career           String
  player           String
  soakValue        Int
  woundsThreshold  Int
  woundsCurrent    Int
  strainThreshold  Int
  strainCurrent    Int
  defenseRanged    Int
  defenseMelee     Int
  brawn            Int      @default(2)
  agility          Int      @default(2)
  intellect        Int      @default(2)
  cunning          Int      @default(2)
  willpower        Int      @default(2)
  presence         Int      @default(2)
  skills           Json?
  weapons          Weapon[]
  armors           Armor[]
  motivations      Json?
  description      Json?
  equipment        Json?
  notes            String?
  criticalInjuries Json?
  talents          Json?
  updatedAt        DateTime @updatedAt
  lastUpdatedBy    String?
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Weapon {
  id         String      @id @default(uuid())
  name       String      @unique
  skill      String
  damage     String
  crit       String
  range      String
  special    String
  data       Json?
  characters Character[]
}

model GlobalCriticalInjury {
  id       String @id @default(uuid())
  type     String // "Crush", "Puncture", "Slash", "Cold", "Electricity", "Heat"
  severity Int
  minRoll  Int
  maxRoll  Int
  name     String
  effect   String
}

model Armor {
  id          String      @id @default(uuid())
  name        String      @unique
  defense     String
  soak        String
  encumbrance String
  hardPoints  String
  special     String
  data        Json?
  characters  Character[]
}

model Adversary {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model AdversaryAbility {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Archetype {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model ArchetypeAbility {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Book {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Career {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Characteristic {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Gear {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model OptionFeature {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Quality {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Rule {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Setting {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Sidebar {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Skill {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Spell {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Table {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Talent {
  id   String @id @default(uuid())
  name String @unique
  data Json
}

model Vehicle {
  id   String @id @default(uuid())
  name String @unique
  data Json
}
